---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>The Context Window</h1>
			<p>
				Adventures in AI-assisted development — one session at a time.
			</p>
			<p>
				This blog synthesizes real sessions of pair-programming with Claude into thematic articles:
				what we built, what broke, what surprised us, and the patterns that emerged along the way.
			</p>
			<p>
				If you're a developer curious about what AI-assisted development actually feels like in practice,
				this is for you.
			</p>
			<p>
				<a href={`${import.meta.env.BASE_URL}blog`}>Read the latest posts &rarr;</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
